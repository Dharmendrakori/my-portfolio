# Aiven MySQL connection settings
# Copy to .env and update values

AIVEN_DB_HOST=
AIVEN_DB_PORT=
AIVEN_DB_USER=
AIVEN_DB_PASSWORD=
AIVEN_DB_NAME=

# API defaults
API_PORT=3001

# Table to read AD users from
# Expected columns (customize in code if your schema differs):
# uid, username, cn, department, title, status, email, last_logon
AIVEN_AD_USERS_TABLE=ad_users
AIVEN_AD_HEALTH_TABLE=ADHealthCheck

# Table to read DHCP health data from
# Expected columns:
# Id, DHCPServer, PingStatus, DHCPServiceStatus, ScopeCount, UsagePercentage, FailoverPartner, FailoverMode, LastChecked
AIVEN_DHCP_HEALTH_TABLE=DHCP_Health_Check

