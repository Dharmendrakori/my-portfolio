# Existing DB config (required for other admin endpoints)
# AIVEN_DB_HOST=
# AIVEN_DB_PORT=3306
# AIVEN_DB_USER=
# AIVEN_DB_PASSWORD=
# AIVEN_DB_NAME=

# AD Users table name (defaults to 'ad_users' if not set)
# AIVEN_AD_USERS_TABLE=ad_users

# Domain password policy table name (defaults to 'domain_password_policy' if not set)
# AIVEN_DOMAIN_PASSWORD_POLICY_TABLE=domain_password_policy

# Port for the API server
# API_PORT=3001

# Contact form integration (Forward to Formspree)
# FORMSPREE_ENDPOINT="https://formspree.io/f/xxxxxx"
# ALLOWED_ORIGIN="https://dharmendrakori.github.io"

