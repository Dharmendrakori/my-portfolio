<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="../public/favicon-config.js"></script>
  <title>M365 License Usage Alert - Live Demo</title>

  <!-- Chart.js for dashboard charts -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>

  <style>
    :root {
      --matrix-green: #00ff41;
      --bg-primary: #0b0e17;
      --bg-secondary: #131724;
      --bg-card: rgba(10, 20, 10, 0.85);
      --bg-card-hover: #1f2740;
      --border-color: rgba(0, 255, 65, 0.15);
      --text-primary: #e8edf5;
      --text-secondary: #8b95b5;
      --text-muted: #5a6488;
      --accent-green: #00c853;
      --accent-green-bg: rgba(0, 200, 83, 0.12);
      --accent-red: #ff1744;
      --accent-red-bg: rgba(255, 23, 68, 0.12);
      --accent-orange: #ff9100;
      --accent-orange-bg: rgba(255, 145, 0, 0.12);
      --accent-blue: #2979ff;
      --accent-blue-bg: rgba(41, 121, 255, 0.12);
      --shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
      --radius: 10px;
      --radius-sm: 6px;
      --transition: all 0.2s ease;
      --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font);
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
    }

    /* Matrix Rain Canvas */
    #matrix-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      opacity: 0.35;
      pointer-events: none;
    }

    .dashboard-container {
      position: relative;
      z-index: 1;
      max-width: 1440px;
      margin: 0 auto;
      padding: 24px 20px;
    }

    /* Header */
    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 32px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border-color);
    }

    .header-left h1 {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #fff 60%, var(--accent-blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .header-left .subtitle {
      font-size: 14px;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    .header-right { text-align: right; }

    .header-right .current-time {
      font-size: 20px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .header-right .current-date {
      font-size: 13px;
      color: var(--text-secondary);
    }

    .header-actions {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .btn {
      padding: 8px 18px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      transition: var(--transition);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font);
    }

    .btn-refresh {
      background: var(--accent-blue-bg);
      color: var(--accent-blue);
      border: 1px solid rgba(41, 121, 255, 0.3);
    }

    .btn-refresh:hover {
      background: rgba(41, 121, 255, 0.2);
      border-color: var(--accent-blue);
    }

    .btn-scan {
      background: var(--accent-green-bg);
      color: var(--accent-green);
      border: 1px solid rgba(0, 200, 83, 0.3);
    }

    .btn-scan:hover {
      background: rgba(0, 200, 83, 0.2);
      border-color: var(--accent-green);
    }

    .btn:disabled {
      opacity: 0.6;
      pointer-events: none;
    }

    /* Threshold Info Banner */
    .threshold-info {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 24px;
      box-shadow: var(--shadow);
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .threshold-info .info-icon {
      font-size: 24px;
      flex-shrink: 0;
    }

    .threshold-info .info-content {
      flex: 1;
      min-width: 200px;
    }

    .threshold-info .info-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .threshold-info .info-text {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .threshold-legend {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      align-items: center;
    }

    .threshold-legend .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-secondary);
    }

    .threshold-legend .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .threshold-legend .legend-dot.green { background: var(--accent-green); }
    .threshold-legend .legend-dot.orange { background: var(--accent-orange); }
    .threshold-legend .legend-dot.red { background: var(--accent-red); }

    /* Summary Cards */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .summary-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow);
      transition: var(--transition);
      position: relative;
      overflow: hidden;
    }

    .summary-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
    }

    .summary-card.total::before { background: var(--accent-blue); }
    .summary-card.healthy::before { background: var(--accent-green); }
    .summary-card.warning::before { background: var(--accent-orange); }
    .summary-card.critical::before { background: var(--accent-red); }

    .summary-card:hover {
      background: var(--bg-card-hover);
      transform: translateY(-2px);
    }

    .summary-card .card-icon {
      font-size: 24px;
      margin-bottom: 8px;
      display: inline-block;
    }

    .summary-card .card-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-secondary);
      margin-bottom: 4px;
    }

    .summary-card .card-value {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
    }

    .summary-card.total .card-value { color: var(--accent-blue); }
    .summary-card.healthy .card-value { color: var(--accent-green); }
    .summary-card.warning .card-value { color: var(--accent-orange); }
    .summary-card.critical .card-value { color: var(--accent-red); }

    /* Charts */
    .charts-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 32px;
    }

    .chart-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow);
    }

    .chart-card h3 {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .chart-wrapper {
      position: relative;
      width: 100%;
      max-height: 280px;
    }

    .chart-wrapper canvas {
      max-height: 280px;
    }

    /* Table */
    .table-section {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .table-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border-color);
    }

    .toolbar-left {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .toolbar-right {
      font-size: 13px;
      color: var(--text-secondary);
    }

    .search-input {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      padding: 8px 14px;
      color: var(--text-primary);
      font-size: 13px;
      width: 220px;
      transition: var(--transition);
      outline: none;
    }

    .search-input:focus {
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 2px rgba(41, 121, 255, 0.2);
    }

    .search-input::placeholder { color: var(--text-muted); }

    .table-wrapper {
      overflow-x: auto;
      padding: 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    thead { background: var(--bg-secondary); }

    thead th {
      padding: 12px 14px;
      text-align: left;
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      white-space: nowrap;
      border-bottom: 1px solid var(--border-color);
    }

    tbody tr {
      border-bottom: 1px solid var(--border-color);
      transition: var(--transition);
    }

    tbody tr:hover { background: rgba(41, 121, 255, 0.05); }

    tbody td {
      padding: 10px 14px;
      white-space: nowrap;
      vertical-align: middle;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.3px;
    }

    .status-badge.healthy {
      background: var(--accent-green-bg);
      color: var(--accent-green);
    }

    .status-badge.warning {
      background: var(--accent-orange-bg);
      color: var(--accent-orange);
    }

    .status-badge.critical {
      background: var(--accent-red-bg);
      color: var(--accent-red);
    }

    .usage-bar {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .usage-bar .bar {
      flex: 1;
      height: 6px;
      background: var(--bg-secondary);
      border-radius: 3px;
      overflow: hidden;
      min-width: 50px;
    }

    .usage-bar .bar .fill {
      height: 100%;
      border-radius: 3px;
      transition: width 0.6s ease;
    }

    .usage-bar .fill.green { background: var(--accent-green); }
    .usage-bar .fill.orange { background: var(--accent-orange); }
    .usage-bar .fill.red { background: var(--accent-red); }

    .usage-text {
      font-weight: 600;
      font-size: 12px;
      min-width: 40px;
      text-align: right;
    }

    .usage-text.green { color: var(--accent-green); }
    .usage-text.orange { color: var(--accent-orange); }
    .usage-text.red { color: var(--accent-red); }

    /* Back link */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.3s;
      margin-bottom: 20px;
    }

    .back-link:hover { color: var(--accent-green); }

    /* Responsive */
    @media (max-width: 768px) {
      .dashboard-header { flex-direction: column; align-items: stretch; gap: 12px; }
      .header-right { text-align: left; }
      .charts-row { grid-template-columns: 1fr; }
      .summary-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .summary-card .card-value { font-size: 24px; }
      table { font-size: 12px; }
      thead th, tbody td { padding: 8px 10px; }
    }

    @media (max-width: 480px) {
      .summary-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
      .summary-card .card-value { font-size: 20px; }
      .header-left h1 { font-size: 20px; }
    }

    /* Loading / Error / Empty states */
    .state-message {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }

    .state-message .icon {
      font-size: 48px;
      margin-bottom: 16px;
      opacity: 0.5;
    }

    .state-message h3 {
      color: var(--text-secondary);
      margin-bottom: 8px;
      font-size: 20px;
    }

    .state-message p {
      font-size: 14px;
      color: var(--text-muted);
    }

    .error-message {
      color: var(--accent-red);
    }
  </style>
</head>
<body>
  <canvas id="matrix-canvas"></canvas>

  <div class="dashboard-container">
    <a href="../../index.html#projects" class="back-link">
      <i class="fas fa-arrow-left"></i> Back to Portfolio
    </a>

    <div class="dashboard-header">
      <div class="header-left">
        <h1>📊 M365 License Usage Alert</h1>
        <p class="subtitle">Enterprise License Monitoring & Threshold Alerting Dashboard</p>
      </div>
      <div class="header-right">
        <div class="current-time" id="currentTime">--:--:--</div>
        <div class="current-date" id="currentDate">---</div>
        <div class="header-actions">
          <button class="btn btn-refresh" id="refreshBtn" onclick="loadData()">⟳ Refresh</button>
          <button class="btn btn-scan" id="scanBtn" onclick="runScan()">▶ Run Scan</button>
        </div>
      </div>
    </div>

    <!-- Threshold Info Banner -->
    <div class="threshold-info">
      <div class="info-icon">ℹ️</div>
      <div class="info-content">
        <div class="info-title">Alert Thresholds</div>
        <div class="info-text">
          Status is determined by each SKU's configured <strong>thresholdPercent</strong>:
          Healthy if threshold ≥ 75%, Warning if threshold is between 40%–50%, Critical if threshold ≤ 30%.
        </div>
      </div>
      <div class="threshold-legend">
        <span class="legend-item"><span class="legend-dot green"></span> Healthy</span>
        <span class="legend-item"><span class="legend-dot orange"></span> Warning</span>
        <span class="legend-item"><span class="legend-dot red"></span> Critical</span>
      </div>
    </div>

    <div class="summary-grid" id="summaryCards">
      <div class="summary-card total">
        <div class="card-icon">📦</div>
        <div class="card-label">Total SKUs</div>
        <div class="card-value" id="totalSkus">--</div>
      </div>
      <div class="summary-card healthy">
        <div class="card-icon">✅</div>
        <div class="card-label">Healthy</div>
        <div class="card-value" id="healthyCount">--</div>
      </div>
      <div class="summary-card warning">
        <div class="card-icon">⚠️</div>
        <div class="card-label">Warning</div>
        <div class="card-value" id="warningCount">--</div>
      </div>
      <div class="summary-card critical">
        <div class="card-icon">🔴</div>
        <div class="card-label">Critical</div>
        <div class="card-value" id="criticalCount">--</div>
      </div>
      <div class="summary-card total">
        <div class="card-icon">👥</div>
        <div class="card-label">Total Assigned</div>
        <div class="card-value" id="totalAssigned">--</div>
      </div>
      <div class="summary-card total">
        <div class="card-icon">🏷️</div>
        <div class="card-label">Total Available</div>
        <div class="card-value" id="totalAvailable">--</div>
      </div>
    </div>

    <div class="charts-row">
      <div class="chart-card">
        <h3>📊 License Health Distribution</h3>
        <div class="chart-wrapper">
          <canvas id="healthChart"></canvas>
        </div>
      </div>
      <div class="chart-card">
        <h3>📈 Usage % by SKU</h3>
        <div class="chart-wrapper">
          <canvas id="usageChart"></canvas>
        </div>
      </div>
    </div>

    <div class="table-section">
      <div class="table-toolbar">
        <div class="toolbar-left">
          <input type="text" class="search-input" id="searchInput" placeholder="🔍 Search by SKU name..." oninput="filterAndRenderTable()">
        </div>
        <div class="toolbar-right">
          <span id="recordCount">0 records</span>
        </div>
      </div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>SKU Name</th>
              <th>Assigned</th>
              <th>Available</th>
              <th>Threshold %</th>
              <th>Usage %</th>
              <th>Status</th>
              <th>Last Checked</th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = 'https://portfolio-api-3sx8.onrender.com';

    let allLicenses = [];
    let filteredLicenses = [];
    let healthChartInstance = null;
    let usageChartInstance = null;

    // Clock
    function updateClock() {
      const now = new Date();
      document.getElementById('currentTime').textContent =
        now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
      document.getElementById('currentDate').textContent =
        now.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Matrix Rain Effect
    (function() {
      const canvas = document.getElementById('matrix-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*()';
      const fontSize = 14;
      let columns = Math.floor(canvas.width / fontSize);
      let drops = Array(columns).fill(1);

      function draw() {
        ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#00ff41';
        ctx.font = fontSize + 'px monospace';

        for (let i = 0; i < drops.length; i++) {
          const text = chars[Math.floor(Math.random() * chars.length)];
          ctx.fillText(text, i * fontSize, drops[i] * fontSize);

          if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) {
            drops[i] = 0;
          }
          drops[i]++;
        }
      }

      setInterval(draw, 50);

      window.addEventListener('resize', () => {
        columns = Math.floor(canvas.width / fontSize);
        drops = Array(columns).fill(1);
      });
    })();

    // Data Access
    async function fetchLicenses() {
      const res = await fetch(`${API_BASE}/api/m365/licenses`);
      if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
      const data = await res.json();
      if (!data.ok) throw new Error(data.error || 'Unknown error');
      return data.licenses || [];
    }

    async function fetchSummary() {
      const res = await fetch(`${API_BASE}/api/m365/licenses/summary`);
      if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
      const data = await res.json();
      if (!data.ok) throw new Error(data.error || 'Unknown error');
      return data.summary;
    }

    async function triggerScan() {
      const res = await fetch(`${API_BASE}/api/m365/licenses/scan`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
      return await res.json();
    }

    // Business Logic
    function getLicenseStatus(license) {
      const threshold = Number(license.thresholdPercent || 80);
      if (threshold >= 75) return 'Healthy';
      if (threshold >= 40 && threshold <= 50) return 'Warning';
      if (threshold <= 30) return 'Critical';
      return 'Healthy';
    }

    function getUsageColor(license) {
      const threshold = Number(license.thresholdPercent || 80);
      if (threshold >= 75) return 'green';
      if (threshold >= 40 && threshold <= 50) return 'orange';
      if (threshold <= 30) return 'red';
      return 'green';
    }

    // Render: Summary Cards
    function renderSummary(summary) {
      document.getElementById('totalSkus').textContent = summary.total || 0;
      document.getElementById('healthyCount').textContent = summary.healthy || 0;
      document.getElementById('warningCount').textContent = summary.warning || 0;
      document.getElementById('criticalCount').textContent = summary.critical || 0;
      document.getElementById('totalAssigned').textContent = (summary.totalAssigned || 0).toLocaleString();
      document.getElementById('totalAvailable').textContent = (summary.totalAvailable || 0).toLocaleString();
    }

    // Render: Charts
    function renderCharts(licenses) {
      // Health Distribution Pie Chart
      let healthy = 0, warning = 0, critical = 0;
      for (const l of licenses) {
        const status = getLicenseStatus(l);
        if (status === 'Healthy') healthy++;
        else if (status === 'Warning') warning++;
        else critical++;
      }

      const pieCtx = document.getElementById('healthChart').getContext('2d');
      if (healthChartInstance) healthChartInstance.destroy();
      healthChartInstance = new Chart(pieCtx, {
        type: 'doughnut',
        data: {
          labels: ['Healthy', 'Warning', 'Critical'],
          datasets: [{
            data: [healthy, warning, critical],
            backgroundColor: [
              getComputedStyle(document.documentElement).getPropertyValue('--accent-green').trim() || '#00c853',
              getComputedStyle(document.documentElement).getPropertyValue('--accent-orange').trim() || '#ff9100',
              getComputedStyle(document.documentElement).getPropertyValue('--accent-red').trim() || '#ff1744'
            ],
            borderWidth: 0,
            hoverOffset: 8
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                color: getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#8b95b5',
                padding: 16,
                font: { size: 12 }
              }
            }
          },
          cutout: '65%'
        }
      });

      // Usage % Bar Chart
      const barCtx = document.getElementById('usageChart').getContext('2d');
      if (usageChartInstance) usageChartInstance.destroy();

      const labels = licenses.map(l => l.skuName || 'Unknown');
      const usageData = licenses.map(l => {
        const total = (l.totalAssigned || 0) + (l.totalAvailable || 0);
        return total > 0 ? Math.round(((l.totalAssigned || 0) / total) * 100) : 0;
      });
      const barColors = usageData.map((pct, i) => {
        const license = licenses[i];
        const threshold = Number(license.thresholdPercent || 80);
        if (threshold >= 75) return getComputedStyle(document.documentElement).getPropertyValue('--accent-green').trim() || '#00c853';
        if (threshold >= 40 && threshold <= 50) return getComputedStyle(document.documentElement).getPropertyValue('--accent-orange').trim() || '#ff9100';
        if (threshold <= 30) return getComputedStyle(document.documentElement).getPropertyValue('--accent-red').trim() || '#ff1744';
        return getComputedStyle(document.documentElement).getPropertyValue('--accent-green').trim() || '#00c853';
      });

      usageChartInstance = new Chart(barCtx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Usage %',
            data: usageData,
            backgroundColor: barColors,
            borderRadius: 4,
            borderSkipped: false,
            barPercentage: 0.6
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          indexAxis: 'y',
          scales: {
            x: {
              min: 0,
              max: 100,
              grid: { color: 'rgba(42, 50, 80, 0.5)' },
              ticks: {
                color: getComputedStyle(document.documentElement).getPropertyValue('--text-muted').trim() || '#5a6488',
                font: { size: 11 }
              }
            },
            y: {
              grid: { display: false },
              ticks: {
                color: getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#8b95b5',
                font: { size: 11 }
              }
            }
          },
          plugins: { legend: { display: false } }
        }
      });
    }

    // Render: Table
    function renderTable(licenses) {
      const tbody = document.getElementById('tableBody');
      if (!tbody) return;

      if (!licenses.length) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="state-message">
              <div class="icon">📋</div>
              <h3>No License Data</h3>
              <p>No M365 license records found. Run a scan to populate data.</p>
            </td>
          </tr>`;
        document.getElementById('recordCount').textContent = '0 records';
        return;
      }

      let html = '';
      for (const l of licenses) {
        const total = (l.totalAssigned || 0) + (l.totalAvailable || 0);
        const usagePct = total > 0 ? Math.round(((l.totalAssigned || 0) / total) * 100) : 0;
        const status = getLicenseStatus(l);
        const colorClass = getUsageColor(l);

        html += '<tr>';
        html += `<td><strong>${escHtml(l.skuName || '—')}</strong></td>`;
        html += `<td>${(l.totalAssigned || 0).toLocaleString()}</td>`;
        html += `<td>${(l.totalAvailable || 0).toLocaleString()}</td>`;
        html += `<td>${Number(l.thresholdPercent || 80)}%</td>`;
        html += `<td>
          <div class="usage-bar">
            <div class="bar">
              <div class="fill ${colorClass}" style="width:${usagePct}%"></div>
            </div>
            <span class="usage-text ${colorClass}">${usagePct}%</span>
          </div>
        </td>`;
        html += `<td><span class="status-badge ${status.toLowerCase()}">● ${status}</span></td>`;
        html += `<td>${l.lastChecked ? new Date(l.lastChecked).toLocaleString() : '—'}</td>`;
        html += '</tr>';
      }

      tbody.innerHTML = html;
      document.getElementById('recordCount').textContent = `${licenses.length} records`;
    }

    // Search & Filter
    function filterAndRenderTable() {
      const search = document.getElementById('searchInput').value.toLowerCase().trim();
      let licenses = allLicenses;

      if (search) {
        licenses = licenses.filter(l => (l.skuName || '').toLowerCase().includes(search));
      }

      filteredLicenses = licenses;
      renderTable(filteredLicenses);
    }

    // Utility
    function escHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // Scan
    async function runScan() {
      const btn = document.getElementById('scanBtn');
      btn.disabled = true;
      btn.textContent = '⟳ Scanning...';

      try {
        const result = await triggerScan();
        console.log('Scan completed:', result);
        await loadData();
      } catch (err) {
        console.error('Scan failed:', err);
        alert(`Scan failed: ${err.message}`);
      } finally {
        btn.disabled = false;
        btn.textContent = '▶ Run Scan';
      }
    }

    // Main Load
    async function loadData() {
      const btn = document.getElementById('refreshBtn');
      btn.classList.add('loading');
      btn.textContent = '⟳ Loading...';

      const tbody = document.getElementById('tableBody');
      if (tbody) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="state-message">
              <div class="icon">⏳</div>
              <h3>Loading license data...</h3>
            </td>
          </tr>`;
      }

      try {
        const [licenses, summary] = await Promise.all([
          fetchLicenses(),
          fetchSummary()
        ]);

        allLicenses = licenses;
        filteredLicenses = [...licenses];

        renderSummary(summary);
        renderCharts(licenses);
        renderTable(licenses);
      } catch (err) {
        console.error('Failed to load license data:', err);
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="state-message error-message">
                <div class="icon">⚠️</div>
                <h3>Failed to Load Data</h3>
                <p>${escHtml(err.message || 'Could not connect to the server.')}</p>
                <button class="btn btn-refresh" onclick="loadData()" style="margin-top:12px;">⟳ Retry</button>
              </td>
            </tr>`;
        }
      } finally {
        btn.classList.remove('loading');
        btn.textContent = '⟳ Refresh';
      }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', loadData);
  </script>
</body>
</html>